# --- Google Calendar (OAuth) ---
# Client ID и Client Secret из OAuth-клиента типа "Веб-приложение".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Refresh-token: получить один раз командой `node scripts/get-refresh-token.mjs`.
GOOGLE_REFRESH_TOKEN=
# Календарь, куда пишем записи. "primary" = основной календарь авторизовавшегося аккаунта.
CALENDAR_ID=primary

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# Ваш chat_id (узнать через @userinfobot)
TELEGRAM_CHAT_ID=
# Секрет для защиты webhook (произвольная строка; передаётся при setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# --- Прочее ---
# Секретный ключ для доступа к /admin (генератор ссылок)
ADMIN_SECRET=
# Секрет для подписи персональных ссылок родителей (произвольная длинная строка)
LINK_SIGNING_SECRET=
# Публичный базовый URL сайта (для генерации ссылок в /admin), напр. https://zapis.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
