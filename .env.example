# Google Calendar (OAuth от имени преподавателя; refresh-token получается один раз)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
CALENDAR_ID=primary

# Postgres (Supabase): пул для serverless-запросов
DATABASE_URL=

# Подпись персональных ссылок записи (любая длинная случайная строка)
LINK_SIGNING_SECRET=

# Ключ веб-админки /admin?key=…
ADMIN_SECRET=

# Telegram-бот (уведомления и CRM)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
# Необязательно: username бота для deep-link (иначе берётся из getMe)
TELEGRAM_BOT_USERNAME=

# ЮKassa (необязательно — без ключей счета остаются без онлайн-оплаты)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Защита cron-эндпоинта (Vercel Cron шлёт Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Публичный адрес сайта (для ссылок из бота и return_url оплаты)
NEXT_PUBLIC_BASE_URL=
